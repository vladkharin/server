model User {
  createdAt DateTime @default(now())
  id        Int      @id @default(autoincrement())
  name      String
  surname   String
  username  String   @unique
  email     String   @unique
  password  String

  // Все участия пользователя в чатах (личных и групповых)
  conversationMemberships ConversationMember[]
  ownedConversations      Conversation[] // все чаты, где пользователь — владелец

  // Отправленные сообщения (для аналитики или поиска)
  sentMessages Message[] @relation("SentMessages")

  @@map("users")
}
