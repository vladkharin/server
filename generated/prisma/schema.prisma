model Conversation {
  id        Int      @id @default(autoincrement())
  type      ConvType @default(DIRECT) // DIRECT, GROUP, SERVER_CHANNEL
  name      String? // null для DIRECT, обязательно для GROUP/SERVER
  avatar    String? // URL аватара чата
  ownerId   Int? // только для GROUP/SERVER (создатель)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Для DIRECT: хэш вида "minId-maxId" → гарантирует уникальность пары
  dmHash String? @unique

  // Связи
  owner    User?                @relation(fields: [ownerId], references: [id])
  members  ConversationMember[]
  messages Message[]
}

// =============== УЧАСТНИКИ ЧАТА ===============
model ConversationMember {
  id             Int       @id @default(autoincrement())
  userId         Int
  conversationId Int
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime? // для отметки прочитанных сообщений
  isOwner        Boolean   @default(false)
  nickname       String? // персональное имя в чате (как в Discord)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

// =============== СООБЩЕНИЯ ===============
model Message {
  id             Int      @id @default(autoincrement())
  content        String
  createdAt      DateTime @default(now())
  senderId       Int
  conversationId Int

  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum ConvType {
  DIRECT // 1 на 1
  GROUP // групповой чат
  SERVER_CHANNEL // канал на сервере (позже)
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

enum FriendStatus {
  PENDING // Запрос отправлен, ждёт подтверждения
  ACCEPTED // Друзья
  BLOCKED // В чёрном списке (опционально)
}

// 👇 Добавляем после модели User
model Friend {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId   Int
  receiverId Int
  status     FriendStatus @default(PENDING)

  sender   User @relation("friendSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("friendReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  // Уникальная пара пользователей (в любом направлении)
  @@unique([senderId, receiverId])
  @@index([status])
  @@map("friends")
}

model User {
  createdAt DateTime @default(now())
  id        Int      @id @default(autoincrement())
  name      String
  surname   String
  username  String   @unique
  email     String   @unique
  password  String

  // Все участия пользователя в чатах (личных и групповых)
  conversationMemberships ConversationMember[]
  ownedConversations      Conversation[] // все чаты, где пользователь — владелец

  // Отправленные сообщения (для аналитики или поиска)
  sentMessages Message[] @relation("SentMessages")

  friendsSent     Friend[] @relation("friendSender")
  friendsReceived Friend[] @relation("friendReceiver")

  @@map("users")
}
